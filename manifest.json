{
  "manifest_version": 3,
  "name": "Textfall",
  "version": "0.1",
  "description": "Catches what you type in forms so a refresh or crash doesn't wipe it out.",

  "permissions": ["storage", "activeTab", "alarms"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}